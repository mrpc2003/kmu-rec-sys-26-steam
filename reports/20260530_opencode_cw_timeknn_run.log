{"type":"tool_use","timestamp":1780123644311,"sessionID":"ses_18871130bffewq6n4uHvDBHFVy","part":{"type":"tool","tool":"write","callID":"tooluse_Cu0Y97oMw1Sziy1qzc6e0o","state":{"status":"error","input":{"filePath":"/tmp/opencode/smoke_cw.py","content":"import sys, time, json\nfrom pathlib import Path\n\nsys.path.insert(0, \"scripts\")\nimport pandas as pd\nimport numpy as np\nfrom paper_guided_next_steps import FeatureConfig, score_split\n\nsplit = Path(\"artifacts/validation/val_random_sqrtpop_seed42\")\nraw = Path(\"data/raw/public/data/train.json\")\nout = Path(\"/tmp/opencode/smoke_out\")\n\nfcfg = FeatureConfig(seed=42, cw_max_users=2000, cw_max_pos_per_user=20)\nt0 = time.time()\nres = score_split(split, raw, out, seed=42, fcfg=fcfg)\ndur = time.time() - t0\n\nscores = pd.read_csv(out / split.name / \"next_step_scores.csv\")\ncw_acc = res[\"cw_meta\"][\"row_accuracy\"]\n\nprint(\"==== SMOKE RESULT ====\")\nprint(f\"duration_sec_total_wall: {dur:.1f}\")\nprint(f\"score_split_duration_sec: {res['duration_sec']}\")\nprint(f\"cw_train_pairs: {res['cw_meta']['train_pairs']} (pos={res['cw_meta']['positive_train_pairs']}, neg={res['cw_meta']['negative_train_pairs']})\")\nprint(f\"CW-lite row_accuracy on {split.name}: {cw_acc:.6f}  (gate >= 0.55 -> {'PASS' if cw_acc >= 0.55 else 'FAIL'})\")\n\nfull = pd.read_csv(out / split.name / \"summary.json\") if False else None\nsj = json.loads((out / split.name / \"summary.json\").read_text())\nprint(\"-- top 6 score columns by row_accuracy --\")\nfor s in sj[\"summaries\"][:6]:\n    print(f\"   {s['score_col']}: row_acc={s['row_accuracy']:.6f} user_acc={s['per_user_mean_accuracy']:.6f}\")\n\nprint(\"-- time-decay BM25 variant finiteness check --\")\nsc = pd.read_csv(out / split.name / \"next_step_scores.csv\")\n# next_step_scores only keeps eval cols; recompute presence from summary feature list instead\n# So instead reload candidate-level via the cw_meta feature_columns which includes the new cols.\nfeat_cols = res[\"cw_meta